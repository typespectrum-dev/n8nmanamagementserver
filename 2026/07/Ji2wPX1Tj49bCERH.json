      "id": "08e39fe0-e75b-403f-8ddf-1949b825f51f",
      "name": "Add BG Blur (16/9)",
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Get the input item\nconst item = $input.item.json;\n// Extract the image URL from the JSON\nconst imageUrl = item.originalImageUrl; // e.g., \"https://schneebesenundrosenkohl.de/storage/2023/08/Griesssbrei.jpg\"\n\n// Target size\nconst width = 1920;\nconst height = 1080;\n\n// High-res for smooth blur\nconst highResWidth = 8000;\nconst highResHeight = Math.round(highResWidth * height / width);\n\n// Blur settings\nconst blurRadiusHigh = Math.round(20 * (highResWidth / width));\nconst blurPower = 3;\n\n// FFmpeg payload for single image processing\nconst payload = {\n  \"inputs\": [\n    {\n      \"file_url\": imageUrl,\n      \"options\": [\n        { \"option\": \"-err_detect\", \"argument\": \"aggressive\" },\n        { \"option\": \"-fflags\", \"argument\": \"discardcorrupt\" },\n        { \"option\": \"-max_error_rate\", \"argument\": \"1.0\" },\n        { \"option\": \"-probesize\", \"argument\": \"100000000\" },\n        { \"option\": \"-analyzeduration\", \"argument\": \"100000000\" }\n      ]\n    }\n  ],\n  \"filters\": [\n    {\n      \"filter\": \"[0:v]format=rgba[formatted];[formatted]split=2[fg][bgraw];[bgraw]scale=\" + highResWidth + \":\" + highResHeight + \":force_original_aspect_ratio=increase,crop=\" + highResWidth + \":\" + highResHeight + \"[bgscaled];[bgscaled]boxblur=luma_radius=\" + blurRadiusHigh + \":luma_power=\" + blurPower + \"[bg];[fg]scale=\" + highResWidth + \":\" + highResHeight + \":force_original_aspect_ratio=decrease,pad=\" + highResWidth + \":\" + highResHeight + \":(ow-iw)/2:(oh-ih)/2:color=0x00000000,format=yuva420p[fgpadded];[bg][fgpadded]overlay=0:0,setsar=1,scale=\" + width + \":\" + height + \"[outv]\"\n    }\n  ],\n  \"outputs\": [\n    {\n      \"options\": [\n        { \"option\": \"-map\", \"argument\": \"[outv]\" },\n        { \"option\": \"-c:v\", \"argument\": \"mjpeg\" },\n        { \"option\": \"-q:v\", \"argument\": \"2\" },\n        { \"option\": \"-f\", \"argument\": \"image2\" },\n        { \"option\": \"-frames:v\", \"argument\": \"1\" },\n        { \"option\": \"-pix_fmt\", \"argument\": \"yuvj420p\" }\n      ]\n    }\n  ],\n  \"metadata\": {\n    \"filesize\": true,\n    \"encoder\": true\n  },\n  \"id\": \"preprocess-image-to-jpeg\"\n};\n\n// Return as single item for FFmpeg node\nreturn { json: payload };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
