        "jsonSchemaExample": "{\n  \"total_images\": 10,\n  \"image_prompts\": [\n    {\n      \"prompt_number\": 1,\n      \"image_prompt\": \"A wide establishing shot of a futuristic cyberpunk city at night, neon lights reflecting in puddles, rain falling heavily, cinematic lighting, 4k resolution.\",\n      \"video_prompt\": \"the city is glowing in a beautiful light.\"\n    },\n    {\n      \"prompt_number\": 2,\n      \"image_prompt\": \"Close-up of a robot's face, metallic skin, glowing blue eyes, expression of sadness, dark alleyway background, dramatic shadows.\",\n      \"video_prompt\": \"the robot is looking at the camera slightly confused.\"\n    },\n    {\n      \"prompt_number\": 3,\n      \"image_prompt\": \"A high-speed chase scene through a busy market, hovercrafts flying overhead, motion blur, vibrant colors, chaos and excitement.\",\n      \"video_prompt\": \"race between the cars, action.\"\n    }\n  ]\n}"
